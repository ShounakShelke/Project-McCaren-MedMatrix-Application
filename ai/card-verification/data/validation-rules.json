{
    "pmjay": {
        "card_format": {
            "type": "Ayushman Bharat PM-JAY",
            "issuer": "National Health Authority",
            "dimensions": {
                "width_mm": 85.6,
                "height_mm": 53.98,
                "aspect_ratio": 1.586
            },
            "elements": {
                "qr_code": {
                    "position": "top-right",
                    "size": "20x20mm",
                    "contains": ["beneficiary_id", "name", "family_id", "state_code"]
                },
                "photo": {
                    "position": "left",
                    "size": "25x30mm"
                },
                "hologram": {
                    "position": "bottom-right",
                    "type": "NHA_security_hologram"
                },
                "logo": {
                    "position": "top-center",
                    "type": "ayushman_bharat_logo"
                }
            }
        },
        "id_formats": {
            "abha_id": {
                "pattern": "^\\d{2}-?\\d{4}-?\\d{4}-?\\d{4}$",
                "length": 14,
                "checksum": "luhn",
                "example": "91-1234-5678-9012"
            },
            "pmjay_id": {
                "pattern": "^[A-Z]{2}\\d{12}$",
                "length": 14,
                "format": "STATE(2)+DISTRICT(3)+FAMILY(7)+MEMBER(2)",
                "example": "MH123456789001"
            }
